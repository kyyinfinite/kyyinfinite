const fs = require('fs');
const config = require('../config');

module.exports = async (sock, m, { command, prefix, args, from, isOwner, sender }) => {
    const dbFile = './database.json';
    let db = JSON.parse(fs.readFileSync(dbFile, 'utf-8'));
    
    if (command === prefix + 'antipm') {
        if (!isOwner) return;
        if (!args[0]) return sock.sendMessage(from, { text: `Contoh: ${prefix}antipm on/off` }, { quoted: m });
        
        const isOn = args[0].toLowerCase() === 'on';
        db.antipm = isOn;
        
        fs.writeFileSync(dbFile, JSON.stringify(db, null, 2));
        return sock.sendMessage(from, { text: `✅ Antipm berhasil di${isOn ? 'aktifkan' : 'nonaktifkan'}.` }, { quoted: m });
    }

    if (db.antipm && !from.endsWith('@g.us') && !isOwner && !m.key.fromMe) {
        try {
            await sock.updateBlockStatus(sender, "block");
        } catch (e) {
            console.log("Gagal blokir PM:", e);
        }
    }
};
